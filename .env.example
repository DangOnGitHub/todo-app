# PostgreSQL Database Connection
DB_URL=jdbc:postgresql://localhost:5432/todoapp
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT Secret (Base64-encoded, minimum 32 bytes)
JWT_SECRET=your-base64-encoded-secret-key-minimum-32-bytes-long

# SMTP Mail Configuration (MailHog via docker-compose for local dev)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@todo.dangdoan.com
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

# Frontend URL (for verification links in emails)
FRONTEND_URL=http://localhost:5173
